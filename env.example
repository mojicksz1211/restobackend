# Backend environment variables (template)
# Copy the needed lines into your real ".env" (do NOT commit real tokens/passwords).

# Server
PORT=2000
SESSION_SECRET=change_me

# Loyverse API Configuration
LOYVERSE_ACCESS_TOKEN=your_access_token_here
LOYVERSE_DEFAULT_BRANCH_ID=1
LOYVERSE_SYNC_INTERVAL=10000
LOYVERSE_AUTO_SYNC=true
LOYVERSE_AUTO_SYNC_LIMIT=500

# Optional ISO string/date to start incremental sync from if there's no checkpoint yet
LOYVERSE_SYNC_SINCE=2026-02-21T00:00:00.000Z

# Safety caps (0 = unlimited)
LOYVERSE_SYNC_MAX_RECEIPTS=0
LOYVERSE_SYNC_MAX_PAGES=0


